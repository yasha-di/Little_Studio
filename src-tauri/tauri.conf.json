{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Little Studio",
  "version": "0.31.2",
  "identifier": "com.littlestudio.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Little Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark",
        "backgroundColor": "#121214"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost blob: data:; media-src 'self' asset: http://asset.localhost blob: data:; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self' https://openrouter.ai ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/media/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Little Studio",
    "copyright": "© 2026 Little Studio",
    "category": "Video",
    "shortDescription": "Creative AI video workspace",
    "longDescription": "Little Studio is a desktop studio for AI video generation: write scenes, generate takes through the OpenRouter video API, keep every version, and build your film project by project.",
    "license": "MIT",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
